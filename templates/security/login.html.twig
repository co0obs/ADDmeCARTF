{% extends 'base.html.twig' %}

{% block title %}Log In — ADDmeCART{% endblock %}

{% block body %}
<div class="auth-wrapper">
    <div class="auth-card auth-card-sm">

        <h1 class="auth-title">🛒 Welcome back</h1>
        <p class="auth-subtitle">Sign in to your ADDmeCART account</p>

        {% if error %}
            <div class="alert alert-error" style="margin-bottom:20px;">
                ⚠ {{ error.messageKey|trans(error.messageData, 'security') }}
            </div>
        {% endif %}

        {% if app.user %}
            <div class="alert alert-success" style="margin-bottom:20px;">
                You are logged in as <strong>{{ app.user.userIdentifier }}</strong>.
                <a href="{{ path('app_logout') }}" style="margin-left:8px;">Logout</a>
            </div>
        {% endif %}

        <form method="post">
            <div class="form-group">
                <label for="inputEmail">Email</label>
                <input type="email" value="{{ last_username }}" name="email" id="inputEmail" autocomplete="email" required autofocus placeholder="you@example.com">
            </div>

            <div class="form-group">
                <label for="inputPassword">Password</label>
                <input type="password" name="password" id="inputPassword" autocomplete="current-password" required placeholder="••••••••">
            </div>

            <input type="hidden" name="_csrf_token" value="{{ csrf_token('authenticate') }}">

            <div style="margin-bottom:24px; display:flex; align-items:center; gap:8px;">
                <input type="checkbox" name="_remember_me" id="remember" style="width:16px; height:16px;">
                <label for="remember" style="margin:0; font-weight:500; color: var(--text-secondary); cursor:pointer;">Remember me</label>
            </div>

            <button type="submit" class="btn btn-primary btn-block btn-lg">Sign In</button>
        </form>

        <p style="text-align:center; margin-top:20px; font-size:0.875rem; color: var(--text-muted);">
            Don't have an account? <a href="/register" style="font-weight:700;">Register here</a>
        </p>

    </div>
</div>
{% endblock %}
