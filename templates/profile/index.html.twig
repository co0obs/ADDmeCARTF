{% extends 'base.html.twig' %}

{% block title %}{% if 'ROLE_SELLER' in user.roles %}Seller Profile{% else %}My Profile{% endif %} — ADDmeCART{% endblock %}

{% block body %}
<div class="page-wrapper-medium">

    <h1 class="page-title">{% if 'ROLE_SELLER' in user.roles %}My Seller Profile{% else %}My Profile{% endif %}</h1>
    <p class="page-subtitle">Manage your account information and delivery addresses</p>

    {# --- Delivery Addresses (only for customers - no sellers or admins) --- #}
    {% if 'ROLE_SELLER' not in user.roles and 'ROLE_ADMIN' not in user.roles %}
    <div class="card" style="margin-bottom:32px;">
        <div class="card-header">Delivery Addresses (Up to 3)</div>
        <div class="card-body">
            <form method="POST">
                <div style="display:grid; gap:16px;">
                    <div class="form-group" style="margin:0;">
                        <label>Address 1 {% if user.defaultAddressIndex == 0 or user.defaultAddressIndex is null %}<span class="badge badge-green">Default</span>{% endif %}</label>
                        <div class="address-row" style="display:flex; gap:8px; align-items:center;">
                            <input type="radio" name="defaultAddress" value="0" {% if user.defaultAddressIndex == 0 or user.defaultAddressIndex is null %}checked{% endif %} style="width:auto;">
                            <input type="text" name="address1" value="{{ user.address1|default('') }}" placeholder="e.g. 123 Main St, City, Province" style="flex:1;">
                        </div>
                    </div>

                    <div class="form-group" style="margin:0;">
                        <label>Address 2 {% if user.defaultAddressIndex == 1 %}<span class="badge badge-green">Default</span>{% endif %}</label>
                        <div class="address-row" style="display:flex; gap:8px; align-items:center;">
                            <input type="radio" name="defaultAddress" value="1" {% if user.defaultAddressIndex == 1 %}checked{% endif %} style="width:auto;">
                            <input type="text" name="address2" value="{{ user.address2|default('') }}" placeholder="e.g. 456 Office Bldg, City, Province" style="flex:1;">
                        </div>
                    </div>

                    <div class="form-group" style="margin:0;">
                        <label>Address 3 {% if user.defaultAddressIndex == 2 %}<span class="badge badge-green">Default</span>{% endif %}</label>
                        <div class="address-row" style="display:flex; gap:8px; align-items:center;">
                            <input type="radio" name="defaultAddress" value="2" {% if user.defaultAddressIndex == 2 %}checked{% endif %} style="width:auto;">
                            <input type="text" name="address3" value="{{ user.address3|default('') }}" placeholder="e.g. 789 Branch, City, Province" style="flex:1;">
                        </div>
                    </div>
                </div>
                <p class="form-hint" style="margin-top:12px;">Select the radio button to set an address as your default delivery address.</p>
                <button type="submit" class="btn btn-primary" style="margin-top:16px;">Save Addresses</button>
            </form>
        </div>
    </div>
    {% endif %}

    {# --- Seller Store Settings (only for sellers) --- #}
    {% if 'ROLE_SELLER' in user.roles %}
    <div class="card" style="margin-bottom:32px;">
        <div class="card-header">Store Settings</div>
        <div class="card-body">
            <form method="POST">
                <div class="form-group">
                    <label>Store Name</label>
                    <input type="text" name="storeName" value="{{ user.storeName }}" placeholder="e.g. Jacob's Tech Shop">
                    <p class="form-hint">This name appears on all your product listings.</p>
                </div>
                <button type="submit" class="btn btn-primary">Save Store Name</button>
            </form>
        </div>
    </div>

    <div class="card">
        <div class="card-header" style="display:flex; justify-content:space-between; align-items:center;">
            My Inventory
            <a href="{{ path('app_product_new') }}" class="btn btn-success btn-sm">+ Add Product</a>
        </div>
        <div class="card-body" style="padding:0;">
            {% if products is empty %}
                <div class="empty-state">
                    <div class="empty-state__icon">📦</div>
                    <div class="empty-state__title">No products listed yet</div>
                    <div class="empty-state__text">Add your first product to start selling.</div>
                </div>
            {% else %}
                <div style="overflow-x: auto; width: 100%;">
                <table class="data-table">
                    <thead>
                        <tr>
                            <th>Product</th>
                            <th>Price</th>
                            <th>Stock</th>
                            <th>Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        {% for item in products %}
                            <tr>
                                <td style="font-weight:600; min-width: 250px; white-space: normal;">
                                    <a href="{{ path('app_product_show', {'id': item.id}) }}" style="display: flex; align-items: center; gap: 12px; color: inherit; text-decoration: none;">
                                        {% if item.thumbnailImage %}
                                            <img src="{{ asset(item.thumbnailImage) }}" alt="thumb" style="width: 48px; height: 48px; object-fit: cover; border-radius: 6px; border: 1px solid var(--border); flex-shrink: 0;">
                                        {% else %}
                                            <div style="width: 48px; height: 48px; background: var(--bg); border-radius: 6px; border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; font-size: 0.6rem; color: var(--text-muted); flex-shrink: 0;">No Img</div>
                                        {% endif %}
                                        <span style="line-height: 1.3;">{{ item.name }}</span>
                                    </a>
                                </td>
                                <td>
                                    {% if item.salePrice %}
                                        <div style="text-decoration: line-through; color: var(--text-muted); font-size: 0.85rem;">₱{{ item.price }}</div>
                                        <div style="color: var(--primary); font-weight: 600;">₱{{ item.salePrice }}</div>
                                    {% else %}
                                        ₱{{ item.price }}
                                    {% endif %}
                                </td>
                                <td>
                                    {% if item.stockQuantity > 0 %}
                                        <span class="badge badge-green">{{ item.stockQuantity }} units</span>
                                    {% else %}
                                        <span class="badge badge-red">Out of Stock</span>
                                    {% endif %}
                                </td>
                                <td>
                                    <div style="display:flex; gap:8px; align-items:center;">
                                        <a href="{{ path('app_product_edit', {'id': item.id}) }}" class="btn btn-ghost btn-sm">Edit</a>
                                        <form method="post" action="{{ path('app_product_delete', {'id': item.id}) }}"
                                              onsubmit="return confirm('Delete {{ item.name }}?');" style="margin:0;">
                                            <input type="hidden" name="_token" value="{{ csrf_token('delete' ~ item.id) }}">
                                            <button type="submit" class="btn btn-danger btn-sm">Delete</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        {% endfor %}
                    </tbody>
                </table>
                </div>
            {% endif %}
        </div>
    </div>
    {% endif %}

</div>
{% endblock %}
