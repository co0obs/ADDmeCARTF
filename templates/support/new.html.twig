{% extends 'base.html.twig' %}

{% block title %}Create Support Ticket{% endblock %}

{% block body %}
<div class="page-wrapper" style="max-width: 600px; margin: 0 auto;">
    <div style="margin-bottom: 24px;">
        <a href="{{ path('app_support_index') }}" class="btn btn-ghost" style="padding-left: 0;">&larr; Back to Tickets</a>
    </div>

    <div class="card" style="padding: 32px;">
        <h1 style="font-size: 1.5rem; font-weight: 800; color: var(--text-primary); margin-bottom: 8px;">Create New Ticket</h1>
        <p style="color: var(--text-muted); margin-bottom: 24px;">Please describe your issue in detail. We will get back to you as soon as possible.</p>

        <form action="{{ path('app_support_new') }}" method="POST" enctype="multipart/form-data">
            <div class="form-group">
                <label class="form-label" for="subject">Subject</label>
                <input type="text" id="subject" name="subject" class="form-control" placeholder="e.g., Missing item from Order #12" required>
            </div>

            <div class="form-group" style="margin-top: 16px;">
                <label class="form-label" for="order_id">Related Order (Optional)</label>
                <select id="order_id" name="order_id" class="form-control">
                    <option value="">-- None --</option>
                    {% for order in orders %}
                        <option value="{{ order.id }}">Order #{{ order.referenceNumber|default(order.id) }} (₱{{ order.totalAmount|number_format(2) }})</option>
                    {% endfor %}
                </select>
            </div>

            <div class="form-group" style="margin-top: 16px;">
                <label class="form-label" for="message">Message</label>
                <textarea id="message" name="message" class="form-control" rows="5" placeholder="Please provide details about your inquiry..." required></textarea>
            </div>

            <div class="form-group" style="margin-top: 16px;">
                <label class="form-label" for="attachment">Attachment (Optional)</label>
                <input type="file" id="attachment" name="attachment" class="form-control" accept="image/*,.pdf" style="padding: 10px;">
                <small style="color: var(--text-muted); display: block; margin-top: 6px;">You can upload an image or PDF to help us understand the issue.</small>
            </div>

            <button type="submit" class="btn btn-primary btn-block" style="margin-top: 24px; padding: 14px;">
                Submit Ticket
            </button>
        </form>
    </div>
</div>
{% endblock %}
