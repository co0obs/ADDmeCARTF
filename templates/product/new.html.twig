{% extends 'base.html.twig' %}

{% block title %}Add New Product — ADDmeCART{% endblock %}

{% block body %}
<div class="auth-wrapper" style="align-items:flex-start;">
    <div class="auth-card auth-card-lg">

        <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:28px;">
            <h1 class="auth-title" style="margin:0; text-align:left;">📦 Add New Product</h1>
            <a href="{{ path('app_product_catalog') }}" class="back-link" style="margin:0;">← Back to Shop</a>
        </div>

        {{ form_start(form) }}

            <div class="form-group">
                {{ form_label(form.name, 'Product Name') }}
                {{ form_widget(form.name, {'attr': {'placeholder': 'e.g. Wireless Earbuds Pro'}}) }}
            </div>

            <div class="form-row">
                <div class="form-group">
                    {{ form_label(form.price, 'Price (₱)') }}
                    {{ form_widget(form.price, {'attr': {'placeholder': '0.00'}}) }}
                </div>
                <div class="form-group">
                    {{ form_label(form.stockQuantity, 'Initial Stock') }}
                    {{ form_widget(form.stockQuantity, {'attr': {'placeholder': '0'}}) }}
                </div>
            </div>

            <div class="form-group">
                {{ form_label(form.category, 'Category') }}
                {{ form_widget(form.category) }}
            </div>

            <div class="form-group">
                <label>Product Image URL</label>
                {{ form_widget(form.thumbnailImage, {'attr': {'placeholder': 'https://example.com/image.jpg'}}) }}
                <p class="form-hint">Right-click an image → "Copy Image Address" → paste here.</p>
            </div>

            <div class="form-group">
                {{ form_label(form.description, 'Description') }}
                {{ form_widget(form.description, {'attr': {'rows': '4', 'placeholder': 'Describe your product…'}}) }}
            </div>

            <button type="submit" class="btn btn-success btn-block btn-lg" style="margin-top:8px;">
                + Save Product
            </button>

        {{ form_end(form) }}

    </div>
</div>
{% endblock %}
