{% extends 'base.html.twig' %}

{% block title %}ADDmeCART — Shop{% endblock %}

{% block body %}
<div class="page-wrapper">

    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; margin-bottom:24px;">
        <div>
            <h1 class="page-title">Product Catalog</h1>
            <p class="page-subtitle">Browse and add items to your cart</p>
        </div>
        {% if is_granted('ROLE_SELLER') %}
            <a href="{{ path('app_product_new') }}" class="btn btn-success">+ Add New Product</a>
        {% endif %}
    </div>

    {# --- SEARCH & FILTERS --- #}
    <div class="search-bar" style="background: var(--surface); padding: 20px; border-radius: var(--radius-lg); border: 1px solid var(--border); box-shadow: var(--shadow-sm);">
        <form method="get" action="{{ path('app_product_catalog') }}" class="filter-form" style="display:grid; grid-template-columns: repeat(auto-fit, minmax(200px, 1fr)); gap:16px; align-items:end; width:100%;">
            
            <div class="form-group" style="margin:0;">
                <label class="form-label">Search Keyword</label>
                <input type="text" name="q" value="{{ currentKeyword|default('') }}" placeholder="Search by name or description…">
            </div>

            <div class="form-group" style="margin:0;">
                <label class="form-label">Category</label>
                <select name="category">
                    <option value="all">All Categories</option>
                    <option value="Electronics" {{ currentCategory|default('') == 'Electronics' ? 'selected' }}>Electronics & Gadgets</option>
                    <option value="Clothing" {{ currentCategory|default('') == 'Clothing' ? 'selected' }}>Clothing & Apparel</option>
                    <option value="Home" {{ currentCategory|default('') == 'Home' ? 'selected' }}>Home & Living</option>
                    <option value="Sports" {{ currentCategory|default('') == 'Sports' ? 'selected' }}>Sports & Outdoors</option>
                    <option value="Beauty" {{ currentCategory|default('') == 'Beauty' ? 'selected' }}>Health & Beauty</option>
                    <option value="Toys" {{ currentCategory|default('') == 'Toys' ? 'selected' }}>Toys & Hobbies</option>
                    <option value="Other" {{ currentCategory|default('') == 'Other' ? 'selected' }}>Other</option>
                </select>
            </div>

            <div class="form-group" style="margin:0;">
                <label class="form-label">Minimum Rating</label>
                <select name="stars">
                    <option value="0">Any Rating</option>
                    <option value="1" {{ currentStars|default(0) == 1 ? 'selected' }}>1+ Star</option>
                    <option value="2" {{ currentStars|default(0) == 2 ? 'selected' }}>2+ Stars</option>
                    <option value="3" {{ currentStars|default(0) == 3 ? 'selected' }}>3+ Stars</option>
                    <option value="4" {{ currentStars|default(0) == 4 ? 'selected' }}>4+ Stars</option>
                    <option value="5" {{ currentStars|default(0) == 5 ? 'selected' }}>5 Stars</option>
                </select>
            </div>

            <div class="form-group" style="margin:0;">
                <label class="form-label">Min Price (₱)</label>
                <input type="number" name="minPrice" value="{{ currentMinPrice|default('') }}" placeholder="0" min="0" step="0.01">
            </div>

            <div class="form-group" style="margin:0;">
                <label class="form-label">Max Price (₱)</label>
                <input type="number" name="maxPrice" value="{{ currentMaxPrice|default('') }}" placeholder="Any" min="0" step="0.01">
            </div>

            <div class="form-group" style="margin:0;">
                <label class="form-label">Sort By Price</label>
                <select name="sort">
                    <option value="default">Default</option>
                    <option value="price_asc" {{ currentSort|default('') == 'price_asc' ? 'selected' }}>Lowest to Highest</option>
                    <option value="price_desc" {{ currentSort|default('') == 'price_desc' ? 'selected' }}>Highest to Lowest</option>
                </select>
            </div>

            <div style="display:flex; gap:8px;">
                <button type="submit" class="btn btn-primary" style="flex:1;">Apply Filters</button>
                {% if currentKeyword|default('') or (currentCategory|default('') and currentCategory|default('') != 'all') or currentStars|default(0) or (currentSort|default('') and currentSort|default('') != 'default') or currentMinPrice|default('') or currentMaxPrice|default('') %}
                    <a href="{{ path('app_product_catalog') }}" class="btn btn-ghost" title="Clear Filters">✕</a>
                {% endif %}
            </div>
        </form>
    </div>

    {# --- PRODUCT GRID --- #}
    <div class="product-grid">
        {% for product in products %}
            <div class="product-card">

                {% if product.thumbnailImage %}
                    <img src="{{ asset(product.thumbnailImage) }}" alt="{{ product.name }}" class="product-card__image">
                {% else %}
                    <div class="product-card__image-placeholder">No Image</div>
                {% endif %}

                <div class="product-card__body">
                    <div class="product-card__category">{{ product.category }}</div>
                    <h3 class="product-card__title">{{ product.name }}</h3>
                    <div class="product-card__seller">
                        Sold by <strong>{{ product.seller.storeName|default('ADDmeCART Official') }}</strong>
                    </div>

                    {% if product.starRating %}
                        <div style="color: #f59e0b; font-size: 0.9rem; margin-bottom: 8px;">
                            {% for i in 1..5 %}
                                {{ i <= product.starRating|round ? '★' : '☆' }}
                            {% endfor %}
                            <span style="color: var(--text-muted); font-size: 0.8rem; margin-left: 4px;">({{ product.starRating|number_format(1) }})</span>
                        </div>
                    {% endif %}

                    <p class="product-card__desc">{{ product.description }}</p>

                    <div class="product-card__footer" style="margin-bottom: 12px;">
                        {% if product.salePrice %}
                            <div>
                                <span style="text-decoration: line-through; color: var(--text-muted); font-size: 0.9rem; margin-right: 8px;">₱{{ product.price|number_format(2) }}</span>
                                <span class="product-card__price">₱{{ product.salePrice|number_format(2) }}</span>
                            </div>
                        {% else %}
                            <span class="product-card__price">₱{{ product.price|number_format(2) }}</span>
                        {% endif %}
                        {% if product.stockQuantity > 0 %}
                            <span class="product-card__stock">{{ product.stockQuantity }} left</span>
                        {% else %}
                            <span class="badge badge-red">Out of Stock</span>
                        {% endif %}
                    </div>

                    <a href="{{ path('app_product_show', {'id': product.id}) }}" class="btn btn-primary btn-block">
                        View Details
                    </a>
                </div>

            </div>
        {% else %}
            <div class="empty-state" style="grid-column: 1 / -1;">
                <div class="empty-state__icon">🔍</div>
                <div class="empty-state__title">No products found</div>
                <div class="empty-state__text">Try adjusting your search terms.</div>
            </div>
        {% endfor %}
    </div>

    {# --- PAGINATION --- #}
    {% if totalPages is defined and totalPages > 1 %}
        <nav class="pagination" aria-label="Product pagination">
            {% if currentPage > 1 %}
                <a href="{{ path('app_product_catalog', app.request.query.all|merge({'page': currentPage - 1})) }}" class="btn btn-ghost btn-sm">&laquo; Prev</a>
            {% endif %}

            {% for i in 1..totalPages %}
                {% if i == currentPage %}
                    <span class="btn btn-primary btn-sm">{{ i }}</span>
                {% elseif i <= 3 or i > totalPages - 2 or (i >= currentPage - 1 and i <= currentPage + 1) %}
                    <a href="{{ path('app_product_catalog', app.request.query.all|merge({'page': i})) }}" class="btn btn-ghost btn-sm">{{ i }}</a>
                {% elseif i == 4 and currentPage > 5 %}
                    <span class="pagination-dots">…</span>
                {% elseif i == totalPages - 2 and currentPage < totalPages - 4 %}
                    <span class="pagination-dots">…</span>
                {% endif %}
            {% endfor %}

            {% if currentPage < totalPages %}
                <a href="{{ path('app_product_catalog', app.request.query.all|merge({'page': currentPage + 1})) }}" class="btn btn-ghost btn-sm">Next &raquo;</a>
            {% endif %}
        </nav>
    {% endif %}

</div>
{% endblock %}
