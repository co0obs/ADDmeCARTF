{% extends 'base.html.twig' %}

{% block title %}ADDmeCART — {{ product.name }}{% endblock %}

{% block body %}
<div class="page-wrapper">
    <div style="margin-bottom: 24px;">
        <a href="{{ path('app_product_catalog') }}" class="btn btn-ghost" style="padding-left: 0;">&larr; Back to Catalog</a>
    </div>

    <div class="product-detail-grid" style="display: grid; grid-template-columns: 1fr 1fr; gap: 40px; background: var(--surface); border-radius: var(--radius-lg); padding: 40px; box-shadow: var(--shadow-md); border: 1px solid var(--border);">
        
        {# Left Side: Image #}
        <div style="display: flex; justify-content: center; align-items: flex-start;">
            {% if product.thumbnailImage %}
                <img src="{{ asset(product.thumbnailImage) }}" alt="{{ product.name }}" style="width: 100%; max-width: 500px; height: auto; object-fit: cover; border-radius: var(--radius-md); border: 1px solid var(--border);">
            {% else %}
                <div style="width: 100%; max-width: 500px; aspect-ratio: 1/1; background: var(--bg); border-radius: var(--radius-md); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--text-muted); font-size: 1.5rem; font-weight: 700;">
                    No Image Available
                </div>
            {% endif %}
        </div>

        {# Right Side: Details #}
        <div style="display: flex; flex-direction: column; gap: 20px;">
            <div>
                <div style="font-size: 0.9rem; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; color: var(--primary); margin-bottom: 8px;">
                    {{ product.category }}
                </div>
                <h1 style="font-size: 2.5rem; font-weight: 800; color: var(--text-primary); line-height: 1.2; margin: 0 0 12px 0; word-break: break-word; overflow-wrap: anywhere;">
                    {{ product.name }}
                </h1>
                <div style="font-size: 1rem; color: var(--text-muted);">
                    Sold by <strong style="color: var(--text-secondary);">{{ product.seller.storeName|default('ADDmeCART Official') }}</strong>
                </div>
            </div>

            <div style="font-size: 2rem; font-weight: 800; color: var(--primary);">
                {% if product.salePrice %}
                    <span style="text-decoration: line-through; color: var(--text-muted); font-size: 1.5rem; margin-right: 12px;">₱{{ product.price|number_format(2) }}</span>
                    <span style="color: var(--primary);">₱{{ product.salePrice|number_format(2) }}</span>
                {% else %}
                    ₱{{ product.price|number_format(2) }}
                {% endif %}
            </div>

            <div style="font-size: 1.1rem; color: var(--text-secondary); line-height: 1.6; word-break: break-word; overflow-wrap: anywhere;">
                {{ product.description }}
            </div>

            <div style="padding: 24px 0; border-top: 1px solid var(--border); border-bottom: 1px solid var(--border); margin-top: auto;">
                <div style="margin-bottom: 16px;">
                    {% if product.stockQuantity > 0 %}
                        <span class="badge badge-green" style="font-size: 0.9rem; padding: 6px 12px;">In Stock: {{ product.stockQuantity }} units available</span>
                    {% else %}
                        <span class="badge badge-red" style="font-size: 0.9rem; padding: 6px 12px;">Out of Stock</span>
                    {% endif %}
                </div>

                <div style="display: flex; flex-direction: column; gap: 12px;">
                    {% if product.stockQuantity > 0 %}
                        <a href="{{ path('app_cart_add', {'id': product.id}) }}" class="btn btn-primary btn-lg" style="text-align: center; font-size: 1.1rem; padding: 16px;">
                            🛒 Add to Cart
                        </a>
                    {% else %}
                        <button class="btn btn-lg btn-block" disabled style="background:#e2e8f0; color:#9aa5b4; cursor:not-allowed; font-size: 1.1rem; padding: 16px;">
                            Out of Stock
                        </button>
                    {% endif %}

                    {% if is_granted('ROLE_CUSTOMER') %}
                        <form method="post" action="{{ path('app_wishlist_add', {'id': product.id}) }}" style="margin: 0;">
                            <button type="submit" class="btn btn-ghost btn-block" style="font-size: 1rem; padding: 14px;">
                                ❤️ Save to Wishlist
                            </button>
                        </form>
                    {% else %}
                        <a href="{{ path('app_login') }}" class="btn btn-ghost btn-block" style="font-size: 1rem; padding: 14px; text-align: center;">
                            Log in to save to wishlist
                        </a>
                    {% endif %}
                </div>
            </div>
        </div>
    </div>

    {# --- REVIEWS SECTION --- #}
    <div class="reviews-section">
        <div class="reviews-header">
            <h2 style="margin: 0; font-size: 1.5rem; font-weight: 700;">Customer Reviews</h2>
            {% if avgRating %}
                <div style="font-size: 1.1rem; color: var(--text-secondary);">
                    <span style="color: #f59e0b; font-size: 1.3rem;">★</span>
                    <strong>{{ avgRating|number_format(1) }}</strong> / 5
                    <span style="color: var(--text-muted);">({{ reviews|length }} review{{ reviews|length != 1 ? 's' : '' }})</span>
                </div>
            {% endif %}
        </div>

        {# Review Form — only for logged-in users #}
        {% if is_granted('ROLE_USER') %}
            <div class="review-form-box">
                <h3 style="margin: 0 0 16px 0; font-size: 1.1rem; font-weight: 600;">Write a Review</h3>
                <form method="post" action="{{ path('app_product_review', {'id': product.id}) }}">
                    {% if app.request.query.get('order_id') %}
                        <input type="hidden" name="order_id" value="{{ app.request.query.get('order_id') }}">
                    {% endif %}
                    <div style="margin-bottom: 16px;">
                        <label style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 0.95rem;">Rating</label>
                        <div style="display: flex; gap: 8px;">
                            {% for i in 1..5 %}
                                <label style="cursor: pointer; font-size: 1.8rem; color: #d1d5db; transition: color 0.2s;">
                                    <input type="radio" name="rating" value="{{ i }}" required style="display: none;">
                                    <span class="star-label" data-value="{{ i }}">★</span>
                                </label>
                            {% endfor %}
                        </div>
                    </div>
                    <div style="margin-bottom: 16px;">
                        <label style="display: block; margin-bottom: 8px; font-weight: 600; font-size: 0.95rem;">Comment (optional)</label>
                        <textarea name="comment" rows="3" placeholder="Share your experience with this product..." style="width: 100%; padding: 12px; border: 1px solid #ddd; border-radius: 8px; font-size: 0.95rem; resize: vertical;"></textarea>
                    </div>
                    <button type="submit" class="btn btn-primary">Submit Review</button>
                </form>
            </div>
        {% else %}
            <div style="background: var(--bg); border-radius: var(--radius-md); padding: 20px; margin-bottom: 24px; text-align: center; border: 1px solid var(--border);">
                <a href="{{ path('app_login') }}" style="color: var(--primary); font-weight: 600;">Log in</a> to leave a review.
            </div>
        {% endif %}

        {# Reviews List #}
        {% for review in reviews %}
            <div style="padding: 20px 0; border-top: 1px solid var(--border);">
                <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 8px;">
                    <div>
                        <strong>{{ review.user.firstName|default('Anonymous') }} {{ review.user.lastName|default('') }}</strong>
                        <span style="color: #f59e0b; margin-left: 8px;">
                            {% for i in 1..5 %}
                                {{ i <= review.rating ? '★' : '☆' }}
                            {% endfor %}
                        </span>
                    </div>
                    <span style="color: var(--text-muted); font-size: 0.85rem;">{{ review.createdAt|date('M d, Y') }}</span>
                </div>
                {% if review.comment %}
                    <p style="margin: 0; color: var(--text-secondary); line-height: 1.5; word-break: break-word; overflow-wrap: anywhere;">{{ review.comment }}</p>
                {% endif %}

                {% if review.sellerReply %}
                    <div style="margin-top: 12px; padding: 12px 16px; background: #f8f9fa; border-left: 4px solid var(--primary); border-radius: 4px;">
                        <div style="font-size: 0.85rem; font-weight: 600; color: var(--primary); margin-bottom: 4px;">
                            Seller Response
                            {% if review.repliedAt %}
                                <span style="color: var(--text-muted); font-weight: 400; margin-left: 8px;">{{ review.repliedAt|date('M d, Y') }}</span>
                            {% endif %}
                        </div>
                        <p style="margin: 0; color: var(--text-secondary); font-size: 0.95rem;">{{ review.sellerReply }}</p>
                    </div>
                {% elseif app.user and product.seller == app.user %}
                    <div style="margin-top: 12px;">
                        <form action="{{ path('app_review_reply', {'id': review.id}) }}" method="POST" style="display: flex; gap: 8px;">
                            <input type="text" name="sellerReply" placeholder="Write a reply to this review..." class="form-control" style="flex: 1; padding: 8px; border: 1px solid #ddd; border-radius: 4px;" required>
                            <button type="submit" class="btn btn-primary btn-sm">Reply</button>
                        </form>
                    </div>
                {% endif %}
            </div>
        {% else %}
            <div style="text-align: center; padding: 24px; color: var(--text-muted);">
                No reviews yet. Be the first to review this product!
            </div>
        {% endfor %}
    </div>

</div>
<style>
    .star-label:hover, .star-label.active { color: #f59e0b !important; }
</style>
<script>
    document.querySelectorAll('.star-label').forEach(function(star) {
        star.addEventListener('click', function() {
            var val = parseInt(this.dataset.value);
            this.closest('form').querySelectorAll('.star-label').forEach(function(s) {
                s.classList.toggle('active', parseInt(s.dataset.value) <= val);
                s.style.color = parseInt(s.dataset.value) <= val ? '#f59e0b' : '#d1d5db';
            });
        });
    });
</script>
{% endblock %}
