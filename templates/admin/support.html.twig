{% extends 'base.html.twig' %}

{% block title %}Manage Support Tickets — Admin{% endblock %}

{% block body %}
<div class="page-wrapper">

    <div style="display:flex; justify-content:space-between; align-items:center; margin-bottom:24px;">
        <div>
            <h1 class="page-title" style="margin-bottom: 0;">🎟️ Support Tickets</h1>
            <p class="page-subtitle">Resolve customer inquiries and issues</p>
        </div>
        <a href="{{ path('app_admin_dashboard') }}" class="btn btn-ghost">&larr; Back to Dashboard</a>
    </div>

    <div class="card">
        <div style="overflow-x:auto;">
            <table class="data-table">
                <thead>
                    <tr>
                        <th>Ticket ID</th>
                        <th>Date</th>
                        <th>Customer</th>
                        <th>Issue</th>
                        <th>Status</th>
                        <th>Admin Action</th>
                    </tr>
                </thead>
                <tbody>
                    {% for ticket in tickets %}
                        <tr>
                            <td style="font-weight:700; font-family: var(--font-mono); font-size:0.85rem;">
                                #{{ ticket.id }}
                            </td>
                            <td style="color: var(--text-muted); font-size:0.85rem;">
                                {{ ticket.createdAt|date('M d, Y h:i A') }}
                            </td>
                            <td>{{ ticket.user.email }}</td>
                            <td style="font-weight:600; color: var(--text-primary); max-width: 300px;">
                                {{ ticket.subject }}
                                {% if ticket.relatedOrder %}
                                    <div style="font-size:0.8rem; color: var(--text-muted); margin-top:4px;">
                                        Order #{{ ticket.relatedOrder.referenceNumber|default(ticket.relatedOrder.id) }}
                                    </div>
                                {% endif %}
                            </td>
                            <td>
                                {% if ticket.status == 'Open' %}
                                    <span class="badge badge-red">Open</span>
                                {% elseif ticket.status == 'In Progress' %}
                                    <span class="badge" style="background:#fef3c7; color:#d97706;">In Progress</span>
                                {% else %}
                                    <span class="badge badge-green">Resolved</span>
                                {% endif %}
                            </td>
                            <td>
                                <a href="{{ path('app_admin_support_show', {'id': ticket.id}) }}" class="btn btn-primary btn-sm">View & Reply</a>
                            </td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="6">
                                <div class="empty-state">
                                    <div class="empty-state__icon">🎉</div>
                                    <div class="empty-state__title">Inbox Zero</div>
                                    <div class="empty-state__text">There are no support tickets right now. Great job!</div>
                                </div>
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
            </table>
        </div>
    </div>
</div>
{% endblock %}
