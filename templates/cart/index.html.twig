{% extends 'base.html.twig' %}

{% block title %}ADDmeCART — My Cart{% endblock %}

{% block body %}
<div class="page-wrapper">

    <h1 class="page-title">My Shopping Cart</h1>

    {% if cartItems|length > 0 %}
        <form action="{{ path('app_checkout_prepare') }}" method="POST" id="cartForm">

        {# Table Header #}
        <div style="background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); overflow: hidden; box-shadow: var(--shadow-sm);">

            <div class="cart-grid-header" style="display: grid; grid-template-columns: 40px 2fr 1fr 1fr 1fr 100px; gap: 16px; padding: 14px 24px; background: var(--bg); border-bottom: 1px solid var(--border); align-items: center;">
                <div style="display: flex; justify-content: center;">
                    <input type="checkbox" id="selectAllCheckbox" style="cursor: pointer; width: 18px; height: 18px;">
                </div>
                <div style="font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted);">Product</div>
                <div style="font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); text-align: center;">Unit Price</div>
                <div style="font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); text-align: center;">Quantity</div>
                <div style="font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); text-align: center;">Total Price</div>
                <div style="font-size: 0.78rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.5px; color: var(--text-muted); text-align: center;">Actions</div>
            </div>

            {% for storeName, items in groupedItems %}
                {# Store Header #}
                <div style="padding: 14px 24px; background: #f8fafc; border-bottom: 1px solid var(--border); display: flex; align-items: center; gap: 12px;">
                    <input type="checkbox" class="store-checkbox" data-store="{{ storeName|e('html_attr') }}" style="cursor: pointer; width: 18px; height: 18px;">
                    <strong style="font-size: 0.95rem; color: var(--text-primary); text-transform: uppercase; letter-spacing: 0.5px;">🏪 {{ storeName }}</strong>
                </div>

                {% for item in items %}
                    <div class="cart-grid-row" style="display: grid; grid-template-columns: 40px 2fr 1fr 1fr 1fr 100px; gap: 16px; padding: 20px 24px; align-items: center; border-bottom: 1px solid var(--border);">
                        <div style="display: flex; justify-content: center;">
                            <input type="checkbox" name="selected_items[]" value="{{ item.id }}" class="item-checkbox" data-store="{{ storeName|e('html_attr') }}" data-price="{{ item.product.effectivePrice * item.quantity }}" style="cursor: pointer; width: 18px; height: 18px;">
                        </div>
    
                        {# Product #}
                        <div style="display: flex; align-items: center; gap: 16px; min-width: 0;">
                            {% if item.product.thumbnailImage %}
                                <img src="{{ item.product.thumbnailImage }}"
                                     alt="{{ item.product.name }}"
                                     style="width: 80px; height: 80px; object-fit: cover; border-radius: var(--radius-md); border: 1px solid var(--border); flex-shrink: 0;">
                            {% else %}
                                <div style="width: 80px; height: 80px; background: var(--bg); border-radius: var(--radius-md); border: 1px solid var(--border); display: flex; align-items: center; justify-content: center; color: var(--text-muted); font-size: 0.7rem; font-weight: 700; flex-shrink: 0;">
                                    No Image
                                </div>
                            {% endif %}
                            <div style="min-width: 0;">
                                <div style="font-weight: 700; color: var(--text-primary); white-space: nowrap; overflow: hidden; text-overflow: ellipsis;">
                                    {{ item.product.name }}
                                </div>
                                <div style="font-size: 0.8rem; color: var(--text-muted); margin-top: 4px;">
                                    {{ item.product.category }}
                                </div>
                            </div>
                        </div>
    
                        {# Unit Price #}
                        <div style="text-align: center; font-weight: 600; color: var(--text-secondary);">
                            {% if item.product.salePrice %}
                                <div style="text-decoration: line-through; font-size: 0.8rem; color: var(--text-muted);">₱{{ item.product.price|number_format(2) }}</div>
                                <div style="color: var(--primary);">₱{{ item.product.salePrice|number_format(2) }}</div>
                            {% else %}
                                ₱{{ item.product.price|number_format(2) }}
                            {% endif %}
                        </div>
    
                        {# Quantity #}
                        <div style="display: flex; justify-content: center;">
                            <div class="qty-control">
                                <a href="{{ path('app_cart_decrease', {'id': item.id}) }}" class="qty-btn">−</a>
                                <span class="qty-value">{{ item.quantity }}</span>
                                <a href="{{ path('app_cart_increase', {'id': item.id}) }}" class="qty-btn">+</a>
                            </div>
                        </div>
    
                        {# Total Price #}
                        <div style="text-align: center; font-weight: 800; color: var(--primary); font-size: 1.05rem;">
                            ₱{{ (item.product.effectivePrice * item.quantity)|number_format(2) }}
                        </div>
    
                        {# Actions #}
                        <div style="display: flex; justify-content: center;">
                            <a href="{{ path('app_cart_remove', {'id': item.id}) }}"
                               style="font-size: 0.85rem; font-weight: 700; color: var(--text-muted); text-decoration: none; transition: color 0.15s;"
                               onmouseover="this.style.color='var(--danger)'"
                               onmouseout="this.style.color='var(--text-muted)'">
                                Delete
                            </a>
                        </div>
    
                    </div>
                {% endfor %}
            {% endfor %}

        </div>

        {# Sticky Checkout Bar #}
        <div class="cart-checkout-bar" style="position: sticky; bottom: 0; background: var(--surface); border: 1px solid var(--border); border-radius: var(--radius-lg); margin-top: 16px; padding: 18px 24px; display: flex; justify-content: flex-end; align-items: center; gap: 32px; box-shadow: var(--shadow-md);">
            <div style="text-align: right;">
                <div style="font-size: 0.8rem; color: var(--text-muted); font-weight: 600; text-transform: uppercase; letter-spacing: 0.5px;">Grand Total</div>
                <div style="font-size: 1.6rem; font-weight: 800; color: var(--primary);" id="grandTotalDisplay">₱{{ total|number_format(2) }}</div>
            </div>
            <button type="submit" id="checkoutBtn" class="btn btn-primary btn-lg" style="padding: 14px 48px; font-size: 1rem; border: none; cursor: pointer;">
                Check Out
            </button>
        </div>
        </form>

    {% else %}
        <div class="empty-state" style="padding-top: 80px;">
            <div class="empty-state__icon">🛒</div>
            <div class="empty-state__title">Your cart is empty</div>
            <div class="empty-state__text" style="margin-bottom: 20px;">Head over to the catalog to add some items!</div>
            <a href="{{ path('app_product_catalog') }}" class="btn btn-primary">Browse Products</a>
        </div>
    {% endif %}

</div>
{% endblock %}

{% block javascripts %}
<script>
document.addEventListener('DOMContentLoaded', function() {
    const selectAllCheckbox = document.getElementById('selectAllCheckbox');
    const storeCheckboxes = document.querySelectorAll('.store-checkbox');
    const itemCheckboxes = document.querySelectorAll('.item-checkbox');
    const grandTotalDisplay = document.getElementById('grandTotalDisplay');
    const checkoutBtn = document.getElementById('checkoutBtn');

    function updateTotals() {
        let total = 0;
        let anyChecked = false;
        let allChecked = true;

        itemCheckboxes.forEach(function(checkbox) {
            if (checkbox.checked) {
                total += parseFloat(checkbox.getAttribute('data-price'));
                anyChecked = true;
            } else {
                allChecked = false;
            }
        });

        if (grandTotalDisplay) {
            grandTotalDisplay.innerHTML = '₱' + total.toLocaleString('en-US', { minimumFractionDigits: 2, maximumFractionDigits: 2 });
        }
        
        if (selectAllCheckbox) {
            selectAllCheckbox.checked = allChecked && itemCheckboxes.length > 0;
        }

        storeCheckboxes.forEach(function(storeCheckbox) {
            const storeName = storeCheckbox.getAttribute('data-store');
            let allStoreItemsChecked = true;
            let hasItems = false;
            
            itemCheckboxes.forEach(function(itemCheckbox) {
                if (itemCheckbox.getAttribute('data-store') === storeName) {
                    hasItems = true;
                    if (!itemCheckbox.checked) {
                        allStoreItemsChecked = false;
                    }
                }
            });
            
            if (hasItems) {
                storeCheckbox.checked = allStoreItemsChecked;
            }
        });

        if (checkoutBtn) {
            if (anyChecked) {
                checkoutBtn.disabled = false;
                checkoutBtn.style.opacity = '1';
                checkoutBtn.style.cursor = 'pointer';
            } else {
                checkoutBtn.disabled = true;
                checkoutBtn.style.opacity = '0.5';
                checkoutBtn.style.cursor = 'not-allowed';
            }
        }
    }

    if (selectAllCheckbox) {
        selectAllCheckbox.addEventListener('change', function() {
            const isChecked = this.checked;
            itemCheckboxes.forEach(function(checkbox) {
                checkbox.checked = isChecked;
            });
            updateTotals();
        });
    }

    storeCheckboxes.forEach(function(storeCheckbox) {
        storeCheckbox.addEventListener('change', function() {
            const storeName = this.getAttribute('data-store');
            const isChecked = this.checked;
            
            itemCheckboxes.forEach(function(itemCheckbox) {
                if (itemCheckbox.getAttribute('data-store') === storeName) {
                    itemCheckbox.checked = isChecked;
                }
            });
            updateTotals();
        });
    });

    itemCheckboxes.forEach(function(checkbox) {
        checkbox.addEventListener('change', updateTotals);
    });

    updateTotals();
});
</script>
{% endblock %}