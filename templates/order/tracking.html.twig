{% extends 'base.html.twig' %}

{% block title %}Live Tracking — ADDmeCART{% endblock %}

{% block stylesheets %}
<link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
{% endblock %}

{% block body %}
<div class="page-wrapper">

    <a href="{{ path('app_user_orders') }}" class="back-link">← Back to My Orders</a>

    <div style="display:flex; justify-content:space-between; align-items:center; flex-wrap:wrap; gap:12px; margin-bottom:28px;">
        <h1 class="page-title" style="margin-bottom:0;">
            Order #{{ order.referenceNumber|default(order.id) }}
        </h1>
        <span class="badge badge-gray" style="font-family: var(--font-mono); font-size:0.8rem; padding:6px 14px;">
            Tracking #: {{ trackingNumber|default(order.trackingNumber) }}
        </span>
    </div>

    <div style="display:grid; grid-template-columns: 1fr 2fr; gap:24px; margin-bottom:28px;">

        {# Status Panel #}
        <div class="card">
            <div class="card-header">Delivery Status</div>
            <div class="card-body">
                <div id="liveStatus" style="font-size:1.3rem; font-weight:800; color: var(--success); margin-bottom:4px;">
                    Fetching…
                </div>
                <p style="color: var(--text-muted); font-size:0.875rem; margin-bottom:20px;">
                    ETA: <strong>{{ eta|default('Today, 4:30 PM') }}</strong>
                </p>

                <hr class="section-divider">

                <div style="display:flex; flex-direction:column; gap:8px; font-size:0.875rem;">
                    <div><span style="color: var(--text-muted);">Courier:</span> <strong id="courierName">—</strong></div>
                    <div><span style="color: var(--text-muted);">Driver:</span> <strong id="driverName">—</strong></div>
                    <div><span style="color: var(--text-muted);">Last Update:</span> <strong id="lastUpdate">—</strong></div>
                </div>

                <button onclick="fetchTrackingData()" class="btn btn-primary btn-block" style="margin-top:20px;">
                    ↻ Refresh GPS
                </button>
            </div>
        </div>

        {# Map #}
        <div class="card" style="overflow:hidden;">
            <div id="gpsMap" style="height:380px; width:100%;"></div>
        </div>

    </div>

    {# Order Summary #}
    <div class="card">
        <div class="card-header">Order Summary</div>
        <div class="card-body" style="padding:0;">
            <table class="data-table">
                <tbody>
                    {% for item in order.orderItems %}
                        <tr>
                            <td>
                                <div style="display:flex; align-items:center; gap:12px;">
                                    <div style="width:44px; height:44px; border-radius: var(--radius-md); overflow:hidden; border:1px solid var(--border); background: var(--bg); flex-shrink:0;">
                                        <img src="{{ item.product.thumbnailImage|default('https://via.placeholder.com/44?text=?') }}"
                                             alt="{{ item.product.name }}"
                                             style="width:100%; height:100%; object-fit:cover;">
                                    </div>
                                    <span style="font-weight:600;">{{ item.product.name }}</span>
                                </div>
                            </td>
                            <td style="text-align:center; color: var(--text-muted);">×{{ item.quantity }}</td>
                            <td style="text-align:right; font-weight:700;">₱{{ (item.price * item.quantity)|number_format(2) }}</td>
                        </tr>
                    {% else %}
                        <tr>
                            <td colspan="3" style="text-align:center; color: var(--danger); font-style:italic; padding:20px;">
                                Old order format — item details not available.
                            </td>
                        </tr>
                    {% endfor %}
                </tbody>
                <tfoot>
                    <tr>
                        <td colspan="2" style="text-align:right; font-weight:700; color: var(--text-secondary); padding:16px;">Grand Total</td>
                        <td style="text-align:right; font-weight:800; color: var(--primary); font-size:1.1rem; padding:16px;">
                            ₱{{ order.totalAmount|number_format(2) }}
                        </td>
                    </tr>
                </tfoot>
            </table>
        </div>
    </div>

</div>

{% block javascripts %}
<script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
<script>
    let map, marker;

    document.addEventListener('DOMContentLoaded', function() {
        map = L.map('gpsMap').setView([12.8797, 121.7740], 5);
        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© OpenStreetMap contributors'
        }).addTo(map);
        fetchTrackingData();
    });

    function fetchTrackingData() {
        fetch('/api/mock-logistics-tracking')
            .then(r => r.json())
            .then(data => {
                document.getElementById('liveStatus').innerText = data.current_status;
                document.getElementById('courierName').innerText = data.courier;
                document.getElementById('driverName').innerText = data.driver_name;
                document.getElementById('lastUpdate').innerText = data.last_update;

                const latLng = [data.current_location.lat, data.current_location.lng];
                if (!marker) {
                    marker = L.marker(latLng).addTo(map)
                        .bindPopup('<b>Package Location</b><br>Driver is nearby!').openPopup();
                } else {
                    marker.setLatLng(latLng);
                }
                map.setView(latLng, 14);
            })
            .catch(err => console.error('Tracking error:', err));
    }
</script>
{% endblock %}

{% endblock %}
